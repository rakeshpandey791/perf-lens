{
  "name": "perf-lens",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "worker"
  ],
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:worker\" \"npm:dev:client\"",
    "dev:client": "npm run dev -w client",
    "dev:server": "npm run dev -w server",
    "dev:worker": "npm run dev -w worker",
    "build": "npm run build -w server && npm run build -w worker && npm run build -w client"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
