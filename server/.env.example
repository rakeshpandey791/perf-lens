PORT=4000
# Use your local Postgres role/user in the URL if needed.
DATABASE_URL=postgresql://127.0.0.1:5432/perf_lens
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
JWT_SECRET=replace-with-strong-secret
UPLOAD_MAX_MB=200
# Optional absolute paths; leave unset to use server/uploads and server/temp defaults
# UPLOAD_DIR=/absolute/path/to/uploads
# TEMP_DIR=/absolute/path/to/temp
# Comma-separated origins supported, e.g. http://localhost:5173,http://localhost:5174
CLIENT_ORIGIN=http://localhost:5173

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_INDIVIDUAL_MONTHLY=
STRIPE_PRICE_INDIVIDUAL_QUARTERLY=
STRIPE_PRICE_INDIVIDUAL_ANNUAL=
BILLING_SUCCESS_URL=http://localhost:5173/profile?billing=success
BILLING_CANCEL_URL=http://localhost:5173/profile?billing=cancelled
TEAM_PLAN_CONTACT_EMAIL=sales@perflens.dev
